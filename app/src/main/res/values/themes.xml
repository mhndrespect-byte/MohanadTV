<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.MohanadTV" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/green_terminal</item>
        <item name="colorPrimaryDark">@color/black_royal</item>
        <item name="colorAccent">@color/green_terminal</item>
        <item name="android:windowBackground">@color/black_royal</item>
        <item name="android:statusBarColor">@color/black_royal</item>
        <item name="android:navigationBarColor">@color/black_royal</item>
        <item name="android:textColorPrimary">@color/white_text</item>
        <item name="android:textColorHint">@color/grey_text</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowIsTranslucent" tools:targetApi="21">false</item>
    </style>

    <style name="Theme.MohanadTV.Player" parent="Theme.MohanadTV">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowBackground">@color/black_royal</item>
    </style>

    <style name="EditText.Terminal">
        <item name="android:background">@drawable/bg_edittext_terminal</item>
        <item name="android:textColor">@color/green_terminal</item>
        <item name="android:textColorHint">@color/grey_text</item>
        <item name="android:padding">12dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:singleLine">true</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <style name="Button.Terminal">
        <item name="android:background">@drawable/bg_button_terminal</item>
        <item name="android:textColor">@color/black_royal</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textAllCaps">false</item>
    </style>

</resources>
