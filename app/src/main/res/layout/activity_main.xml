<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_royal"
    android:orientation="vertical">

    <!-- شريط العنوان البسيط -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textColor="@color/green_terminal"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/text_network_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="●"
            android:textColor="@color/green_terminal"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- منطقة إدخال رابط القائمة -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/edit_m3u_url"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:hint="@string/hint_m3u_url"
            android:inputType="textUri"
            android:imeOptions="actionDone"
            style="@style/EditText.Terminal" />

        <Button
            android:id="@+id/btn_load_playlist"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:paddingHorizontal="16dp"
            android:text="@string/btn_load"
            android:minWidth="0dp"
            android:minHeight="0dp"
            style="@style/Button.Terminal" />
    </LinearLayout>

    <!-- شريط البحث السريع -->
    <EditText
        android:id="@+id/edit_search"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_margin="14dp"
        android:hint="@string/hint_search"
        android:inputType="text"
        android:visibility="gone"
        style="@style/EditText.Terminal" />

    <!-- شريط الفئات الأفقي -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_categories"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:paddingHorizontal="14dp"
        android:orientation="horizontal"
        android:visibility="gone"
        tools:listitem="@layout/item_category_chip" />

    <!-- حالة فارغة (قبل تحميل أي قائمة) -->
    <LinearLayout
        android:id="@+id/layout_empty_state"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📡"
            android:textSize="40sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/empty_state"
            android:textColor="@color/grey_text"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:gravity="center" />
    </LinearLayout>

    <!-- قائمة القنوات الرئيسية -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_channels"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone"
        tools:listitem="@layout/item_channel" />

    <!-- شريط تحميل بسيط أسفل الشاشة -->
    <ProgressBar
        android:id="@+id/progress_loading"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:indeterminate="true"
        android:indeterminateTint="@color/green_terminal"
        android:visibility="gone" />

</LinearLayout>
