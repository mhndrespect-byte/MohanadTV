#!/bin/sh
##############################################################################
# Gradle start up script - يُستخدم لبناء المشروع من سطر الأوامر
# للبناء داخل Android Studio، هذا الملف غير ضروري - فقط افتح المشروع به مباشرة
##############################################################################
DIR="$(cd "$(dirname "$0")" && pwd)"
exec java -jar "$DIR/gradle/wrapper/gradle-wrapper.jar" "$@"
